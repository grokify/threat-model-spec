      "type": "string",
      "enum": [
        "soc2",
        "pci-dss",
        "hipaa",
        "gdpr",
        "ccpa",
        "fedramp",
        "nist-sp-800-53",
        "nist-sp-800-171",
        "sox",
        "glba"
      ]
