        "title": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "direction": {
          "$ref": "#/$defs/Direction"
        },
        "legend": {
          "$ref": "#/$defs/Legend"
        },
        "mappings": {
          "$ref": "#/$defs/Mappings"
        },
        "elements": {
          "items": {
            "$ref": "#/$defs/Element"
          },
          "type": "array"
        },
        "boundaries": {
          "items": {
            "$ref": "#/$defs/Boundary"
          },
          "type": "array"
        },
        "flows": {
          "items": {
            "$ref": "#/$defs/Flow"
          },
          "type": "array"
        },
        "attacks": {
          "items": {
            "$ref": "#/$defs/Attack"
          },
          "type": "array"
        },
        "targets": {
          "items": {
            "$ref": "#/$defs/Target"
          },
          "type": "array"
        },
        "actors": {
          "items": {
            "$ref": "#/$defs/Actor"
          },
          "type": "array"
        },
        "phases": {
          "items": {
            "$ref": "#/$defs/Phase"
          },
          "type": "array"
        },
        "messages": {
          "items": {
            "$ref": "#/$defs/Message"
          },
          "type": "array"
