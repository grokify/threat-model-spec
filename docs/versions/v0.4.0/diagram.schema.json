    "CVSSMapping": {
      "properties": {
        "version": {
          "type": "string"
        },
        "vector": {
          "type": "string"
        },
        "baseScore": {
          "type": "number"
        },
        "severity": {
          "$ref": "#/$defs/CVSSSeverity"
        },
        "description": {
          "type": "string"
        }
      },
      "additionalProperties": false,
      "type": "object",
      "required": [
        "version",
        "vector",
        "baseScore",
        "severity"
      ]
