        "type": {
          "$ref": "#/$defs/ElementType"
        },
        "parentId": {
          "type": "string"
        },
        "classification": {
          "$ref": "#/$defs/AssetClassification"
        },
        "strideThreats": {
          "items": {
            "$ref": "#/$defs/STRIDEThreat"
          },
          "type": "array"
        },
        "description": {
          "type": "string"
        }
      },
      "additionalProperties": false,
      "type": "object",
      "required": [
        "id",
        "label",
        "type"
      ]
    },
    "ElementType": {
      "type": "string",
      "enum": [
        "process",
        "datastore",
        "external-entity",
        "gateway",
        "browser",
        "agent",
        "api"
      ]
    },
    "Flow": {
      "properties": {
        "from": {
