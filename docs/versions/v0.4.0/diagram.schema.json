        "high",
        "medium",
        "low"
      ]
    },
    "Attack": {
      "properties": {
        "step": {
          "type": "integer"
        },
        "from": {
          "type": "string"
        },
        "to": {
          "type": "string"
        },
        "label": {
          "type": "string"
        },
        "mitreTactic": {
          "$ref": "#/$defs/MITRETactic"
        },
        "mitreTechnique": {
          "type": "string"
        },
        "strideThreats": {
