        "mitigations": {
          "items": {
            "$ref": "#/$defs/Mitigation"
          },
          "type": "array"
        },
        "detections": {
          "items": {
            "$ref": "#/$defs/Detection"
          },
          "type": "array"
        },
        "responseActions": {
          "items": {
            "$ref": "#/$defs/ResponseAction"
          },
          "type": "array"
        }
      },
      "additionalProperties": false,
      "type": "object",
      "required": [
        "type",
        "title"
      ]
