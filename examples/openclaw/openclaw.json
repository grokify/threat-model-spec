      "title": "CVE-2024-XXXXX (Example)",
      "url": "https://cve.mitre.org/",
      "type": "cve"
    },
    {
      "title": "WebSocket Security Best Practices",
      "url": "https://cheatsheetseries.owasp.org/cheatsheets/WebSockets_Cheat_Sheet.html",
      "type": "advisory"
    }
  ],
