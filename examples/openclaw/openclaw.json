{
  "id": "openclaw-websocket-localhost-takeover",
  "title": "OpenClaw WebSocket Localhost Takeover",
  "description": "A critical vulnerability in OpenClaw AI agent gateway that allows malicious websites to hijack developer sessions through WebSocket connections to localhost. The attack exploits missing origin validation and lack of rate limiting to steal API keys, conversation logs, and configuration data.",
  "version": "1.0.0",
  "authors": [
    {
      "name": "John Wang",
      "url": "https://github.com/grokify"
    }
  ],
  "references": [
