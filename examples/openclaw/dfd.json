{
  "type": "dfd",
  "title": "OpenClaw Data Flow Diagram",
  "description": "Normal system architecture showing how OpenClaw AI agent operates",
  "direction": "right",
  "mappings": {
    "owasp": [
      {
        "category": "llm",
        "id": "LLM06:2025",
        "name": "Excessive Agency",
        "description": "System grants AI agent broad access to sensitive resources"
      },
      {
        "category": "api",
        "id": "API8:2023",
        "name": "Security Misconfiguration",
        "description": "Architecture relies on implicit localhost trust"
      }
    ],
    "cwe": [
      {
        "id": "CWE-346",
        "name": "Origin Validation Error",
        "description": "WebSocket gateway does not validate connection origins"
      }
    ],
    "stride": [
      {
        "category": "I",
        "name": "Information Disclosure",
        "description": "Sensitive data stores accessible via gateway",
        "affectedComponents": ["api-keys", "config", "logs"]
      }
    ]
  },
  "legend": {
    "show": true,
    "showElements": true,
    "showBoundaries": true,
    "showAssets": true
  },
  "boundaries": [
    {
      "id": "browser-zone",
      "label": "Browser Sandbox",
      "type": "browser",
      "description": "Untrusted browser environment"
    },
    {
      "id": "localhost-zone",
      "label": "Localhost (Implicit Trust)",
      "type": "localhost",
      "description": "Trusted local environment"
    }
  ],
  "elements": [
    {
      "id": "user",
      "label": "Developer",
      "type": "external-entity",
      "description": "Human developer using the AI agent"
    },
    {
      "id": "ide",
      "label": "IDE / Editor",
      "type": "process",
      "description": "Development environment"
    },
    {
      "id": "web-ui",
      "label": "OpenClaw Web UI",
      "type": "browser",
      "parentId": "browser-zone"
    },
    {
      "id": "gateway",
      "label": "OpenClaw Gateway",
      "type": "gateway",
      "parentId": "localhost-zone"
    },
    {
      "id": "agent",
      "label": "AI Agent (Claude Code)",
      "type": "agent",
      "parentId": "localhost-zone"
    },
    {
      "id": "api-keys",
      "label": "API Keys (OpenAI, Anthropic)",
      "type": "datastore",
      "parentId": "localhost-zone",
      "classification": "crown-jewel",
      "description": "Stored API credentials"
    },
    {
      "id": "config",
      "label": "Configuration",
      "type": "datastore",
      "parentId": "localhost-zone",
      "classification": "high"
    },
    {
      "id": "logs",
      "label": "Conversation Logs",
      "type": "datastore",
      "parentId": "localhost-zone",
      "classification": "high",
      "description": "May contain code snippets and secrets"
    },
    {
      "id": "devices",
      "label": "Registered Devices",
      "type": "datastore",
      "parentId": "localhost-zone"
    },
    {
      "id": "llm-api",
      "label": "LLM API (Claude, GPT)",
      "type": "api",
      "description": "External AI service"
    }
  ],
  "flows": [
    {
      "from": "user",
      "to": "ide",
      "label": "Writes code",
      "type": "normal"
    },
    {
      "from": "user",
      "to": "web-ui",
      "label": "Manages agent",
      "type": "normal"
    },
    {
      "from": "ide",
      "to": "agent",
      "label": "Code assistance requests",
      "type": "normal",
      "bidirectional": true
    },
    {
      "from": "web-ui",
      "to": "gateway",
      "label": "WebSocket (ws://localhost)",
      "type": "normal",
      "bidirectional": true
    },
    {
      "from": "gateway",
      "to": "agent",
      "label": "Commands / Responses",
      "type": "normal",
      "bidirectional": true
    },
    {
      "from": "gateway",
      "to": "config",
      "label": "Read/Write config",
      "type": "normal"
    },
    {
      "from": "gateway",
      "to": "logs",
      "label": "Write logs",
      "type": "normal"
    },
    {
      "from": "gateway",
      "to": "devices",
      "label": "Manage devices",
      "type": "normal"
    },
    {
      "from": "agent",
      "to": "api-keys",
      "label": "Use API keys",
      "type": "normal"
    },
    {
      "from": "agent",
      "to": "llm-api",
      "label": "LLM requests",
      "type": "normal",
      "bidirectional": true
    }
  ]
}
