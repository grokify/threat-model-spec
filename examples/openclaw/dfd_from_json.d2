# OpenClaw Data Flow Diagram
# Normal system architecture showing how OpenClaw AI agent operates

direction: right

legend: Legend {
  style: {
    fill: "#fafafa"
    stroke: "#e0e0e0"
    border-radius: 8
  }

  assets: Asset Classification {
    style.fill: "#ffffff"
    crown: Crown Jewel { style: { fill: "#ffcdd2"; stroke: "#b71c1c"; stroke-width: 3 } }
    high: High Value { style: { fill: "#fff3e0"; stroke: "#ef6c00"; stroke-width: 2 } }
  }

  elements: Element Types {
    style.fill: "#ffffff"
    process: Process { shape: rectangle; style: { fill: "#e3f2fd"; stroke: "#1976d2" } }
    datastore: Data Store { shape: cylinder; style: { fill: "#fce4ec"; stroke: "#c2185b" } }
    external: External Entity { shape: person; style: { fill: "#e8f5e9"; stroke: "#388e3c" } }
  }

  boundaries: Trust Boundaries {
    style.fill: "#ffffff"
    browser: Browser { style: { stroke-dash: 5; stroke: "#1565c0"; fill: "#e3f2fd" } }
    localhost: Localhost { style: { stroke-dash: 5; stroke: "#7b1fa2"; fill: "#f3e5f5" } }
  }
}

# Trust Boundaries
browser-zone: Browser Sandbox {
  style: {
    stroke-dash: 5
    stroke: "#1565c0"
    fill: "#e3f2fd"
    stroke-width: 2
    border-radius: 10
  }

  web-ui: OpenClaw Web UI {
    shape: rectangle
    style: {
      fill: "#e3f2fd"
      stroke: "#1565c0"
      stroke-width: 2
    }
  }

}

localhost-zone: Localhost (Implicit Trust) {
  style: {
    stroke-dash: 5
    stroke: "#7b1fa2"
    fill: "#f3e5f5"
    stroke-width: 2
    border-radius: 10
  }

  gateway: OpenClaw Gateway {
    shape: hexagon
    style: {
      fill: "#e0f2f1"
      stroke: "#00796b"
      stroke-width: 2
    }
  }

  agent: AI Agent (Claude Code) {
    shape: rectangle
    style: {
      fill: "#e8eaf6"
      stroke: "#3f51b5"
      stroke-width: 2
    }
  }

  api-keys: API Keys (OpenAI, Anthropic) {
    shape: cylinder
    style: {
      fill: "#ffcdd2"
      stroke: "#b71c1c"
      stroke-width: 3
    }
  }

  config: Configuration {
    shape: cylinder
    style: {
      fill: "#fff3e0"
      stroke: "#ef6c00"
      stroke-width: 2
    }
  }

  logs: Conversation Logs {
    shape: cylinder
    style: {
      fill: "#fff3e0"
      stroke: "#ef6c00"
      stroke-width: 2
    }
  }

  devices: Registered Devices {
    shape: cylinder
    style: {
      fill: "#fce4ec"
      stroke: "#c2185b"
      stroke-width: 2
    }
  }

}

user: Developer {
  shape: person
  style: {
    fill: "#e8f5e9"
    stroke: "#388e3c"
    stroke-width: 2
  }
}

ide: IDE / Editor {
  shape: rectangle
  style: {
    fill: "#e3f2fd"
    stroke: "#1976d2"
    stroke-width: 2
  }
}

llm-api: LLM API (Claude, GPT) {
  shape: cloud
  style: {
    fill: "#fff3e0"
    stroke: "#ef6c00"
    stroke-width: 2
  }
}


# Data Flows
user -> ide: Writes code {
  style.stroke: "#616161"
}
user -> web-ui: Manages agent {
  style.stroke: "#616161"
}
ide <-> agent: Code assistance requests {
  style.stroke: "#616161"
}
web-ui <-> gateway: WebSocket (ws://localhost) {
  style.stroke: "#616161"
}
gateway <-> agent: Commands / Responses {
  style.stroke: "#616161"
}
gateway -> config: Read/Write config {
  style.stroke: "#616161"
}
gateway -> logs: Write logs {
  style.stroke: "#616161"
}
gateway -> devices: Manage devices {
  style.stroke: "#616161"
}
agent -> api-keys: Use API keys {
  style.stroke: "#616161"
}
agent <-> llm-api: LLM requests {
  style.stroke: "#616161"
}
