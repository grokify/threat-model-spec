# OpenClaw Data Flow Diagram (DFD)
# Normal system architecture with trust boundaries
# https://github.com/grokify/threat-model-spec

direction: right

# ============================================================================
# Legend
# ============================================================================

legend: Legend {
  style: {
    fill: "#fafafa"
    stroke: "#e0e0e0"
    border-radius: 8
  }

  elements: Element Types {
    style.fill: "#ffffff"

    process: Process {
      shape: rectangle
      style: {
        fill: "#e3f2fd"
        stroke: "#1976d2"
        stroke-width: 2
        border-radius: 8
      }
    }

    datastore: Data Store {
      shape: cylinder
      style: {
        fill: "#fce4ec"
        stroke: "#c2185b"
        stroke-width: 2
      }
    }

    external: External Entity {
      shape: person
      style: {
        fill: "#e8f5e9"
        stroke: "#388e3c"
        stroke-width: 2
      }
    }
  }

  boundaries: Trust Boundaries {
    style.fill: "#ffffff"

    browser-ex: Browser (Untrusted) {
      style: {
        stroke-dash: 5
        stroke: "#1565c0"
        fill: "#e3f2fd"
        border-radius: 8
      }
    }

    localhost-ex: Localhost (Trusted) {
      style: {
        stroke-dash: 5
        stroke: "#7b1fa2"
        fill: "#f3e5f5"
        border-radius: 8
      }
    }
  }
}

# ============================================================================
# External Entities
# ============================================================================

user: Developer {
  shape: person
  style: {
    fill: "#e8f5e9"
    stroke: "#388e3c"
    stroke-width: 2
  }
}

ide: IDE / Editor {
  shape: rectangle
  style: {
    fill: "#fff3e0"
    stroke: "#ef6c00"
    stroke-width: 2
    border-radius: 8
  }
}

llm-api: LLM API (Claude, GPT) {
  shape: cloud
  style: {
    fill: "#e8eaf6"
    stroke: "#3f51b5"
    stroke-width: 2
  }
}

# ============================================================================
# Browser Trust Boundary
# ============================================================================

browser-zone: Browser Sandbox {
  style: {
    stroke-dash: 5
    stroke: "#1565c0"
    stroke-width: 2
    fill: "#e3f2fd"
    border-radius: 10
  }

  web-ui: OpenClaw Web UI {
    shape: rectangle
    style: {
      fill: "#bbdefb"
      stroke: "#1976d2"
      stroke-width: 2
      border-radius: 8
    }
  }
}

# ============================================================================
# Localhost Trust Boundary
# ============================================================================

localhost-zone: Localhost (Implicit Trust) {
  style: {
    stroke-dash: 5
    stroke: "#7b1fa2"
    stroke-width: 2
    fill: "#f3e5f5"
    border-radius: 10
  }

  gateway: OpenClaw Gateway {
    shape: hexagon
    style: {
      fill: "#e0f2f1"
      stroke: "#00796b"
      stroke-width: 2
    }
  }

  agent: AI Agent (Claude Code) {
    shape: rectangle
    style: {
      fill: "#e8eaf6"
      stroke: "#3f51b5"
      stroke-width: 2
      border-radius: 8
    }
  }

  config: Configuration {
    shape: cylinder
    style: {
      fill: "#fce4ec"
      stroke: "#c2185b"
      stroke-width: 2
    }
  }

  logs: Activity Logs {
    shape: cylinder
    style: {
      fill: "#fce4ec"
      stroke: "#c2185b"
      stroke-width: 2
    }
  }

  devices: Registered Devices {
    shape: cylinder
    style: {
      fill: "#fce4ec"
      stroke: "#c2185b"
      stroke-width: 2
    }
  }

  api-keys: API Keys & Secrets {
    shape: cylinder
    style: {
      fill: "#ffcdd2"
      stroke: "#b71c1c"
      stroke-width: 2
    }
  }
}

# ============================================================================
# Normal Data Flows
# ============================================================================

# User interactions
user -> ide: Writes code {
  style.stroke: "#616161"
}

user -> browser-zone.web-ui: Manages agent {
  style.stroke: "#616161"
}

# IDE to Agent
ide -> localhost-zone.agent: Code assistance requests {
  style.stroke: "#1976d2"
  style.stroke-width: 2
}

localhost-zone.agent -> ide: Code suggestions {
  style.stroke: "#1976d2"
  style.stroke-width: 2
}

# Browser to Gateway (WebSocket)
browser-zone.web-ui -> localhost-zone.gateway: WebSocket (ws://localhost) {
  style.stroke: "#7b1fa2"
  style.stroke-width: 2
}

localhost-zone.gateway -> browser-zone.web-ui: Status updates {
  style.stroke: "#7b1fa2"
  style.stroke-width: 2
}

# Gateway internal flows
localhost-zone.gateway -> localhost-zone.agent: Commands {
  style.stroke: "#00796b"
  style.stroke-width: 2
}

localhost-zone.agent -> localhost-zone.gateway: Responses {
  style.stroke: "#00796b"
  style.stroke-width: 2
}

localhost-zone.gateway -> localhost-zone.config: Read/Write config {
  style.stroke: "#c2185b"
}

localhost-zone.gateway -> localhost-zone.logs: Write logs {
  style.stroke: "#c2185b"
}

localhost-zone.gateway -> localhost-zone.devices: Manage devices {
  style.stroke: "#c2185b"
}

localhost-zone.agent -> localhost-zone.api-keys: Use API keys {
  style.stroke: "#b71c1c"
}

# External API
localhost-zone.agent -> llm-api: LLM requests {
  style.stroke: "#3f51b5"
  style.stroke-width: 2
}

llm-api -> localhost-zone.agent: LLM responses {
  style.stroke: "#3f51b5"
  style.stroke-width: 2
}
